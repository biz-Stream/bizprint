{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell",
  "permissions": {
    "deny": [
      "Bash"
    ],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "PowerShell(cd *)",
      "PowerShell(ls *)",
      "PowerShell(mvn clean*)",
      "PowerShell(mvn test*)",
      "PowerShell(mvn package*)",
      "PowerShell(mvn verify*)",
      "PowerShell(mvn compile*)",
      "PowerShell(mvn install*)",
      "PowerShell(mvn checkstyle:*)",
      "PowerShell(mvn editorconfig:*)",
      "PowerShell(which *)",
      "PowerShell(git status*)",
      "PowerShell(git log*)",
      "PowerShell(git diff*)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git push*)",
      "PowerShell(git pull*)",
      "PowerShell(git fetch*)",
      "PowerShell(git checkout*)",
      "PowerShell(git switch*)",
      "PowerShell(git branch*)",
      "PowerShell(git rev-parse*)",
      "PowerShell(git tag*)",
      "PowerShell(git stash*)",
      "PowerShell(git rm*)",
      "PowerShell(git -C*)",
      "PowerShell(tasklist*)",
      "PowerShell(gh issue list*)",
      "PowerShell(gh issue view*)",
      "PowerShell(gh issue create*)",
      "PowerShell(gh pr list*)",
      "PowerShell(gh pr view*)",
      "PowerShell(gh pr create*)",
      "PowerShell(gh pr diff*)",
      "PowerShell(gh pr comment*)",
      "PowerShell(gh pr merge*)",
      "PowerShell(gh run list*)",
      "PowerShell(gh run view*)",
      "PowerShell(gh api repos/*/issues*)",
      "PowerShell(gh api repos/*/pulls*)",
      "PowerShell(gh api repos/*/comments*)",
      "PowerShell(gh repo view*)",
      "PowerShell(gh release list*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "& \"$env:CLAUDE_PROJECT_DIR/.claude/scripts/guard-main-branch.ps1\"",
            "shell": "powershell"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Set-Location $env:CLAUDE_PROJECT_DIR; Write-Output '=== 作業コンテキスト ==='; Write-Output \"ブランチ: $(git rev-parse --abbrev-ref HEAD 2>$null)\"; Write-Output '--- 最近のコミット (5件) ---'; git log --oneline -5 2>$null; Write-Output '--- 変更中のファイル ---'; git status --short 2>$null; Write-Output '==='",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  }
}
