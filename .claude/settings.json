{
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell",
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "PowerShell(cd:*)",
      "PowerShell(ls:*)",
      "PowerShell(file:*)",
      "PowerShell(mvn clean*)",
      "PowerShell(mvn test*)",
      "PowerShell(mvn package*)",
      "PowerShell(mvn verify*)",
      "PowerShell(mvn compile*)",
      "PowerShell(mvn install*)",
      "PowerShell(mvn checkstyle:*)",
      "PowerShell(mvn editorconfig:*)",
      "PowerShell(wc:*)",
      "PowerShell(which:*)",
      "PowerShell(git:*)",
      "PowerShell(tasklist*)",
      "PowerShell(gh issue list*)",
      "PowerShell(gh issue view*)",
      "PowerShell(gh issue create*)",
      "PowerShell(gh pr list*)",
      "PowerShell(gh pr view*)",
      "PowerShell(gh pr create*)",
      "PowerShell(gh pr diff*)",
      "PowerShell(gh pr comment*)",
      "PowerShell(gh run list*)",
      "PowerShell(gh run view*)",
      "PowerShell(gh api*)",
      "PowerShell(gh repo view*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/guard-main-branch.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && echo '=== コンテキスト圧縮後の作業コンテキスト ===' && echo \"ブランチ: $(git rev-parse --abbrev-ref HEAD 2>/dev/null)\" && echo '--- 最近のコミット (5件) ---' && git log --oneline -5 2>/dev/null && echo '--- 変更中のファイル ---' && git status --short 2>/dev/null && echo '==='"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  }
}
